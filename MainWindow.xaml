<Window x:Class="FPS_Benchmarker.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="FPS Benchmarker" Height="450" Width="800">
    <Grid>
        <TextBlock Text="FPS Benchmarker" FontSize="24" HorizontalAlignment="Center" Margin="0,20,0,0"/>
        <Button Content="Start Benchmark" Width="150" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBlock x:Name="FPSDisplay" Text="Current FPS: 0" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,20,0,20"/>
    </Grid>
</Window>